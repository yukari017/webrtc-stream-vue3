# ============================================
#   WebRTC Stream Vue3 - 环境变量配置
# ============================================
#
# 使用说明：
# 1. 复制此文件为 .env.production（生产环境）
# 2. 根据实际部署情况修改配置项
# 3. 开发环境使用 .env.development，无需复制此文件
#
# ============================================

# --------------------------------------------
#   信令服务器配置
# --------------------------------------------
# WebSocket 信令服务器地址
# - 开发环境: wss://localhost:3001
# - 生产环境: wss://your-domain.com/ws (nginx 代理)
# - 直连模式: wss://your-domain.com:3001

VITE_SIGNALING_SERVER_URL=wss://your-domain.com/ws

# --------------------------------------------
#   调试配置
# --------------------------------------------
# 是否启用调试模式
# - true:  开启控制台日志，便于排查问题
# - false: 关闭日志，生产环境推荐

VITE_DEBUG=false
