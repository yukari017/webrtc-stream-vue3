# ============================================
#   WebRTC Stream Vue3 - 开发环境配置
# ============================================
#
# 此文件用于本地开发，无需修改
# 生产环境请使用 .env.production
#
# ============================================

# --------------------------------------------
#   信令服务器配置
# --------------------------------------------
# 本地开发使用 localhost

VITE_SIGNALING_SERVER_URL=wss://localhost:3001

# --------------------------------------------
#   调试配置
# --------------------------------------------
# 开发环境启用调试

VITE_DEBUG=true
