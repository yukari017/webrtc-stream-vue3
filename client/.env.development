# ============================================
#   WebRTC Stream Vue3 - 开发环境配置
# ============================================

# 信令服务器地址
VITE_SIGNALING_SERVER_URL=wss://localhost:3001

# 调试模式
VITE_DEBUG=true

# --------------------------------------------
#   局域网测试
# --------------------------------------------
# 如需局域网测试，创建 .env.development.local 文件：
#   VITE_SIGNALING_SERVER_URL=wss://你的局域网IP:3001
#   VITE_DEBUG=true
# 详见 README.md「局域网测试」章节
